<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.example.Jogo_da_Sueca"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Needed for using camera-->
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@drawable/sueca"
        android:label="@string/app_name"
        android:theme="@style/Theme.Sueca">

        <activity
            android:name="com.example.Jogo_da_Sueca.MainMenuActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>


        <activity
            android:name="com.example.Jogo_da_Sueca.RoomActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.Jogo_da_Sueca.OnlineMenuActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.Jogo_da_Sueca.GameActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.Jogo_da_Sueca.VisionActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.Jogo_da_Sueca.HybridActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.Jogo_da_Sueca.HybridMenuActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.Jogo_da_Sueca.RoomHybridActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

    </application>
</manifest>
