<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/background_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back_arrow" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sala: ---"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSeatHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Escolhe o teu lugar (+)"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/roomVisibilityContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/imgRoomVisibilityLock"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/score_pill_minimal"
                android:clickable="true"
                android:contentDescription="Alternar visibilidade da sala"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_lock_open"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtRoomVisibilityHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="end"
                android:text="Qualquer pessoa pode entrar"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>


    <RelativeLayout
        android:id="@+id/seatChooserLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="46dp"
        android:background="@drawable/section_outline"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="30dp">

        <TextView
            android:id="@+id/seatNorthLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="N"
            android:textSize="34sp"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeatNorth"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_below="@id/seatNorthLabel"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4dp"
            android:text="+"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            app:backgroundTint="#33FFFFFF"
            app:cornerRadius="24dp"
            app:rippleColor="#66FFFFFF" />

        <TextView
            android:id="@+id/txtSeatNorthPlayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/btnSeatNorth"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxWidth="120dp"
            android:singleLine="true"
            android:text="Livre"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/seatSouthLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:text="S"
            android:textSize="34sp"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeatSouth"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_above="@id/seatSouthLabel"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="4dp"
            android:text="+"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            app:backgroundTint="#33FFFFFF"
            app:cornerRadius="24dp"
            app:rippleColor="#66FFFFFF" />

        <TextView
            android:id="@+id/txtSeatSouthPlayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/btnSeatSouth"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="4dp"
            android:ellipsize="end"
            android:maxWidth="120dp"
            android:singleLine="true"
            android:text="Livre"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/seatWestLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="W"
            android:textSize="34sp"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeatWest"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="30dp"
            android:layout_toEndOf="@id/seatWestLabel"
            android:text="+"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            app:backgroundTint="#33FFFFFF"
            app:cornerRadius="24dp"
            app:rippleColor="#66FFFFFF" />

        <TextView
            android:id="@+id/txtSeatWestPlayer"
            android:layout_width="63dp"
            android:layout_height="wrap_content"
            android:layout_below="@+id/seatWestLabel"
            android:layout_alignStart="@+id/seatWestLabel"
            android:layout_marginStart="-15dp"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Livre"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/seatEastLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:text="E"
            android:textSize="34sp"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeatEast"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="30dp"
            android:layout_toStartOf="@id/seatEastLabel"
            android:text="+"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            app:backgroundTint="#33FFFFFF"
            app:cornerRadius="24dp"
            app:rippleColor="#66FFFFFF" />

        <TextView
            android:id="@+id/txtSeatEastPlayer"
            android:layout_width="63dp"
            android:layout_height="wrap_content"
            android:layout_below="@+id/seatEastLabel"
            android:layout_alignEnd="@+id/seatEastLabel"
            android:layout_marginTop="9dp"
            android:layout_marginEnd="-18dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Livre"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

    </RelativeLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartHybridGame"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:text="Iniciar jogo hibrido"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/teal_700"
        app:cornerRadius="12dp"
        android:visibility="gone"/>

</LinearLayout>
