<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="42dp">

        <LinearLayout
            android:id="@+id/createRoomContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Voltar"
                android:src="@drawable/ic_back_arrow" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateRoom"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="+ Criar Sala"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                app:backgroundTint="@color/orange"
                app:cornerRadius="23dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Jogo Hibrido"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDisplayedName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.9"
            android:text="Nome exibido: Player"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:background="@drawable/section_outline"
            android:orientation="vertical"
            android:padding="10dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtHybridRoomsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Cria uma sala para aparecer aqui."
                        android:textColor="#D5E2EC"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:id="@+id/hybridRoomsListContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/joinRoomContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/section_outline"
            android:orientation="vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/inputRoomId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_bg"
                android:hint="ID da sala"
                android:imeOptions="actionDone"
                android:inputType="textCapCharacters|textVisiblePassword"
                android:maxLines="1"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@android:color/white"
                android:textColorHint="#D5E2EC" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinRoom"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="Entrar na Sala"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/orange"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="110dp">

        <ImageView
            android:id="@+id/image_friends"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Abrir amigos"
            android:padding="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_friends" />

        <TextView
            android:id="@+id/friend_requests_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-6dp"
            android:background="@drawable/friend_requests_badge_bg"
            android:gravity="center"
            android:minWidth="18dp"
            android:minHeight="18dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <ImageView
        android:id="@+id/image_profile2"
        android:layout_width="67dp"
        android:layout_height="67dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/profile_avatar_circle"
        android:clipToOutline="true"
        android:contentDescription="Abrir perfil"
        android:outlineProvider="background"
        android:scaleType="centerCrop"
        android:src="@drawable/profile_pic1" />

</FrameLayout>
