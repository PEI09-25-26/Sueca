<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/background_gradient"
    android:fillViewport="true"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"
            android:background="@drawable/section_outline" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp">

            <ImageView
                android:id="@+id/friend_info_banner"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/banner_background"
                android:scaleType="centerCrop" />

            <FrameLayout
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_gravity="center"
                android:translationY="28dp">

                <ImageView
                    android:id="@+id/friend_info_avatar"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:background="@drawable/profile_avatar_circle"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:scaleType="centerCrop" />

                <View
                    android:id="@+id/friend_info_status"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/status_indicator_online" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/friend_info_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Username"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/friend_info_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/section_outline"
            android:minHeight="72dp"
            android:padding="12dp"
            android:text="Descricao"
            android:textColor="@android:color/white"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/friend_info_stats_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Estatisticas:"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/section_outline"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/friend_info_stat_wins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vitorias: x"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/friend_info_stat_winrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Win Rate: x%"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/friend_info_stat_total_games"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Jogos Totais: x"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/friend_info_stat_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Streak de Vitorias: x"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/friend_info_stat_friend_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Amigos: x"
                android:textColor="@android:color/white"
                android:textSize="16sp" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/friend_info_action_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/friend_info_accept"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Aceitar"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/online_green"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/friend_info_reject"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Recusar"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/badge_red"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/friend_info_remove_friend"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Remover amigo"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/badge_red"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/friend_info_open_profile"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Ver perfil completo"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/teal_700"
            app:cornerRadius="10dp" />
    </LinearLayout>
</ScrollView>
