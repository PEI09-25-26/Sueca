<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient">

    <!-- Main content vertically centered -->
    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/sueca"
            android:contentDescription="Logo"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jogo da Sueca"
            android:textSize="28sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Entrar / Criar Sala"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/orange"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVision"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="▶ Jogar com visão artificial"
            android:textAllCaps="false"
            app:backgroundTint="@color/teal_700"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp"
            android:layout_marginTop="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHybrid"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="◼ Jogar modo hibrido (camera/mesa)"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/orange"
            app:cornerRadius="12dp" />

    </LinearLayout>

    <!-- Friends image top-right (left of profile) -->
    <ImageView
        android:id="@+id/image_friends"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="110dp"
        android:contentDescription="Abrir amigos"
        android:padding="0dp"
        android:src="@drawable/ic_friends"
        android:scaleType="fitCenter"/>

    <!-- Profile image top-right -->
    <ImageView
        android:id="@+id/image_profile2"
        android:layout_width="67dp"
        android:layout_height="67dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="Abrir perfil"
        android:background="@drawable/profile_avatar_circle"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:src="@drawable/profile_pic1"
        android:scaleType="centerCrop"/>
</FrameLayout>