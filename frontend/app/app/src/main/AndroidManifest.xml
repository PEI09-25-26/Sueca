<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.example.MVP"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Needed for using camera-->
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:name=".SuecaApp"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@drawable/sueca"
        android:label="@string/app_name"
        android:theme="@style/Theme.Sueca">

        <activity
            android:name="com.example.MVP.LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.MVP.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.VerifyEmailActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.MainMenuActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>


        <activity
            android:name="com.example.MVP.RoomActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.OnlineMenuActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.GameActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.VisionActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.HybridActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.HybridMenuActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.RoomHybridActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.EditActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name="com.example.MVP.FriendsActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

    </application>
</manifest>
