<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolhe a foto de perfil"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_pic1_option"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_margin="6dp"
            android:contentDescription="Selecionar foto de perfil 1"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_pic1"
            app:shapeAppearanceOverlay="@style/ProfilePictureCircle"
            app:strokeColor="@android:color/white"
            app:strokeWidth="1dp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_pic2_option"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_margin="6dp"
            android:contentDescription="Selecionar foto de perfil 2"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_pic2"
            app:shapeAppearanceOverlay="@style/ProfilePictureCircle"
            app:strokeColor="@android:color/white"
            app:strokeWidth="1dp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_pic3_option"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_margin="6dp"
            android:contentDescription="Selecionar foto de perfil 3"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_pic3"
            app:shapeAppearanceOverlay="@style/ProfilePictureCircle"
            app:strokeColor="@android:color/white"
            app:strokeWidth="1dp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_pic4_option"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_margin="6dp"
            android:contentDescription="Selecionar foto de perfil 4"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_pic4"
            app:shapeAppearanceOverlay="@style/ProfilePictureCircle"
            app:strokeColor="@android:color/white"
            app:strokeWidth="1dp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_pic5_option"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_margin="6dp"
            android:contentDescription="Selecionar foto de perfil 5"
            android:scaleType="centerCrop"
            android:src="@drawable/profile_pic5"
            app:shapeAppearanceOverlay="@style/ProfilePictureCircle"
            app:strokeColor="@android:color/white"
            app:strokeWidth="1dp" />

    </GridLayout>

</LinearLayout>
