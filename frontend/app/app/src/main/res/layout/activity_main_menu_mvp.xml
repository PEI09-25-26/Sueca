<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient">

    <!-- Main content vertically centered -->
    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/sueca"
            android:contentDescription="Logo"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jogo da Sueca"
            android:textSize="28sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Jogar"
            android:textAllCaps="false"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/orange"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:id="@+id/playOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:text="Escolhe o modo de jogo"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVirtual"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Jogo Virtual"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/teal_700"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPresential"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="Jogo Presencial com árbitro"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/teal_700"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHybrid"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="Jogo Híbrido"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/teal_700"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Friends image top-right (left of profile) with pending requests badge -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="110dp">

        <ImageView
            android:id="@+id/image_friends"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Abrir amigos"
            android:padding="0dp"
            android:src="@drawable/ic_friends"
            android:scaleType="fitCenter"/>

        <TextView
            android:id="@+id/friend_requests_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-6dp"
            android:background="@drawable/friend_requests_badge_bg"
            android:gravity="center"
            android:minWidth="18dp"
            android:minHeight="18dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Profile image top-right -->
    <ImageView
        android:id="@+id/image_profile2"
        android:layout_width="67dp"
        android:layout_height="67dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="Abrir perfil"
        android:background="@drawable/profile_avatar_circle"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:src="@drawable/profile_pic1"
        android:scaleType="centerCrop"/>
</FrameLayout>