<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/container_profile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/section_outline"
            android:orientation="vertical"
            android:padding="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="170dp">

                <ImageView
                    android:id="@+id/banner_profile"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/banner_background"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/image_profile"
                    android:layout_width="106dp"
                    android:layout_height="104dp"
                    android:layout_gravity="center"
                    android:background="@drawable/profile_circle"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    android:translationY="24dp" />

                <ImageView
                    android:id="@+id/backButton3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:contentDescription="Voltar"
                    android:src="@drawable/ic_back_arrow" />

            </FrameLayout>

            <TextView
                android:id="@+id/name_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="nomedaconta"
                android:textColor="@android:color/white"
                    android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/description_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:gravity="center"
                android:minHeight="72dp"
                android:text="isto aqui é uma descição super fixe. Qual é a tua opinião sobre descrições grandes? concordo!"
                android:textColor="@android:color/white"
                    android:textSize="17sp" />

            <TextView
                android:id="@+id/statisticstext_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Estatísticas:"
                android:textColor="@android:color/white"
                    android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/container2_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/section_outline"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/stat_vitorias_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Vitórias: x"
                    android:textColor="@android:color/white"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/stat_winrate_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Win Rate: x%"
                    android:textColor="@android:color/white"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/stat_total_games_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Jogos Totais: x"
                    android:textColor="@android:color/white"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/stat_win_streak_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Streak de Vitórias: x"
                    android:textColor="@android:color/white"
                    android:textSize="17sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/edit_profile"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="44dp"
                android:layout_marginBottom="8dp"
                android:text="Editar Perfil"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="19sp"
                app:backgroundTint="@color/teal_700"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/leave_account_profile"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="60dp"
                android:text="Sair da Conta"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="19sp"
                app:backgroundTint="@color/teal_700"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </LinearLayout>

</ScrollView>