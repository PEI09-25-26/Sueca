<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient">

    <!-- Back button -->

    <ImageView
        android:id="@+id/backButton3"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="start"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_back_arrow" />

    <!-- Main container -->
    <LinearLayout
        android:id="@+id/container_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/section_outline"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <!-- Banner + Profile -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="134dp">

            <!-- Banner -->
            <ImageView
                android:id="@+id/banner_profile"
                android:layout_width="345dp"
                android:layout_height="114dp"
                android:background="@drawable/banner_background"
                android:scaleType="centerCrop" />

            <!-- Profile picture centered -->
            <ImageView
                android:id="@+id/image_profile"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:background="@drawable/profile_circle"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:translationY="23dp" />
        </FrameLayout>

        <!-- Username -->
        <TextView
            android:id="@+id/name_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="nomedaconta"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Description -->

        <TextView
            android:id="@+id/description_profile"
            android:layout_width="wrap_content"
            android:layout_height="72dp"
            android:layout_marginTop="10dp"
            android:text="isto aqui é uma descição super fixe. Qual é a tua opinião sobre descrições grandes? concordo!"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <!-- User Statistics Section -->

        <LinearLayout
            android:id="@+id/container2_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:background="@drawable/section_outline">

            <!-- Vitórias -->
            <TextView
                android:id="@+id/statisticstext_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Estatísticas:"
                android:textColor="@android:color/white"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stat_vitorias_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vitórias: x"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>

            <!-- Win Rate -->
            <TextView
                android:id="@+id/stat_winrate_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Win Rate: x%"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>

            <!-- Jogos Totais -->
            <TextView
                android:id="@+id/stat_total_games_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jogos Totais: x"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>

            <!-- Streak de Vitorias -->
            <TextView
                android:id="@+id/stat_win_streak_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Streak de Vitórias: x"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/edit_profile"
            android:layout_width="243dp"
            android:layout_height="48dp"
            android:layout_marginTop="25dp"
            android:text="Editar Perfil"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/teal_700"
            android:textSize="18sp"
            app:cornerRadius="12dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/leave_account_profile"
            android:layout_width="243dp"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Sair da Conta"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/teal_700"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>