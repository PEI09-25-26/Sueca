<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:padding="12dp">

    <ImageView
        android:id="@+id/backButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_back_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <LinearLayout
        android:id="@+id/headerInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="#1F000000"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/backButton"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtPhase"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sueca Virtual"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTeamScores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/score_pill_minimal"
                android:fontFamily="sans-serif-medium"
                android:gravity="end|center_vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Pontuacao N/S: 0 | E/O: 0"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Pontuacao N/S: 63 | E/O: 47"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtTrump"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trunfo: ?"
                android:textColor="#FFD166"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txtCurrentPlayer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#26000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="Vez: ?"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerInfo" />

    <TextView
        android:id="@+id/txtEndBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="#40FFD700"
        android:gravity="center"
        android:padding="10dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtCurrentPlayer"
        tools:text="TEAM 1 (N/S) WINS&#10;Final score: 72 - 48&#10;Match points: 2 - 1" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tableContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp"
        android:padding="10dp"
        app:layout_constraintBottom_toTopOf="@id/txtStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtEndBanner">

        <LinearLayout
            android:id="@+id/identityPartner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/slotPartner"
            app:layout_constraintEnd_toEndOf="@id/slotPartner"
            app:layout_constraintHorizontal_bias="0.504"
            app:layout_constraintStart_toStartOf="@id/slotPartner"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.285">

            <ImageView
                android:id="@+id/slotPartnerAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/profile_avatar_circle"
                android:clipToOutline="true"
                android:foreground="@drawable/avatar_glow_gold"
                android:outlineProvider="background"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/profile_pic1" />

            <TextView
                android:id="@+id/slotPartnerName"
                android:layout_width="181dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="Parceiro" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/identityLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/slotLeft"
            app:layout_constraintEnd_toEndOf="@id/slotLeft">

            <ImageView
                android:id="@+id/slotLeftAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/profile_avatar_circle"
                android:clipToOutline="true"
                android:foreground="@drawable/avatar_glow_silver"
                android:outlineProvider="background"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/profile_pic2" />

            <TextView
                android:id="@+id/slotLeftName"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="Esquerda" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/identityRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/slotRight"
            app:layout_constraintEnd_toEndOf="@id/slotTrumpRight">

            <ImageView
                android:id="@+id/slotRightAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/profile_avatar_circle"
                android:clipToOutline="true"
                android:foreground="@drawable/avatar_glow_silver"
                android:outlineProvider="background"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/profile_pic3" />

            <TextView
                android:id="@+id/slotRightName"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="Direita" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/slotPartner"
            android:layout_width="70dp"
            android:layout_height="100dp"
            android:layout_marginTop="70dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/slotLeft"
            android:layout_width="70dp"
            android:layout_height="100dp"
            android:layout_marginStart="39dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.6" />

        <FrameLayout
            android:id="@+id/slotRight"
            android:layout_width="70dp"
            android:layout_height="100dp"
            android:layout_marginEnd="39dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.6" />

        <FrameLayout
            android:id="@+id/slotPlayer"
            android:layout_width="70dp"
            android:layout_height="100dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/miniDeckPartner"
            android:layout_width="36dp"
            android:layout_height="50dp"
            android:layout_marginStart="3dp"
            android:layout_marginBottom="60dp"
            app:layout_constraintBottom_toBottomOf="@id/slotPartner"
            app:layout_constraintStart_toEndOf="@id/slotPartner">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|start"
                android:rotation="-7"
                android:src="@drawable/card_back" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:layout_gravity="top|end"
                android:rotation="6"
                android:src="@drawable/card_back" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/miniDeckRight"
            android:layout_width="36dp"
            android:layout_height="50dp"
            android:layout_marginStart="3dp"
            android:layout_marginBottom="60dp"
            app:layout_constraintBottom_toBottomOf="@id/slotRight"
            app:layout_constraintStart_toEndOf="@id/slotRight">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|start"
                android:rotation="-7"
                android:src="@drawable/card_back" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:layout_gravity="top|end"
                android:rotation="6"
                android:src="@drawable/card_back" />
        </FrameLayout>

        <TextView
            android:id="@+id/slotTrumpPartnerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            android:text="Trunfo"
            android:textColor="#FFD166"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/slotTrumpPartner"
            app:layout_constraintEnd_toEndOf="@id/slotTrumpPartner"
            app:layout_constraintStart_toStartOf="@id/slotTrumpPartner" />

        <FrameLayout
            android:id="@+id/slotTrumpPartner"
            android:layout_width="27dp"
            android:layout_height="47dp"
            android:layout_marginTop="24dp"
            app:layout_constraintBottom_toBottomOf="@id/slotPartner"
            app:layout_constraintEnd_toEndOf="@id/miniDeckPartner"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/miniDeckPartner"
            app:layout_constraintTop_toBottomOf="@id/miniDeckPartner"
            app:layout_constraintVertical_bias="1.0" />

        <TextView
            android:id="@+id/slotTrumpLeftLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            android:text="Trunfo"
            android:textColor="#FFD166"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/slotTrumpLeft"
            app:layout_constraintEnd_toEndOf="@id/slotTrumpLeft"
            app:layout_constraintStart_toStartOf="@id/slotTrumpLeft" />

        <FrameLayout
            android:id="@+id/slotTrumpLeft"
            android:layout_width="27dp"
            android:layout_height="47dp"
            android:layout_marginEnd="3dp"
            app:layout_constraintBottom_toBottomOf="@id/slotLeft"
            app:layout_constraintEnd_toStartOf="@id/slotLeft" />

        <TextView
            android:id="@+id/slotTrumpRightLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            android:text="Trunfo"
            android:textColor="#FFD166"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/slotTrumpRight"
            app:layout_constraintEnd_toEndOf="@id/slotTrumpRight"
            app:layout_constraintStart_toStartOf="@id/slotTrumpRight" />

        <FrameLayout
            android:id="@+id/slotTrumpRight"
            android:layout_width="27dp"
            android:layout_height="47dp"

            android:layout_marginEnd="3dp"
            app:layout_constraintBottom_toBottomOf="@id/slotRight"
            app:layout_constraintEnd_toStartOf="@id/slotRight"


            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/miniDeckRight" />

        <TextView
            android:id="@+id/slotTrumpPlayerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            android:text="Trunfo"
            android:textColor="#FFD166"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/slotTrump"
            app:layout_constraintEnd_toEndOf="@id/slotTrump"
            app:layout_constraintStart_toStartOf="@id/slotTrump" />

        <FrameLayout
            android:id="@+id/slotTrump"
            android:layout_width="27dp"
            android:layout_height="47dp"
            android:layout_marginStart="3dp"
            app:layout_constraintBottom_toBottomOf="@id/slotPlayer"
            app:layout_constraintStart_toEndOf="@id/slotPlayer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#16000000"
        android:gravity="center"
        android:padding="8dp"
        android:text="A ligar..."
        android:textColor="@android:color/white"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@id/layoutActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/handLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/handLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="A tua mao"
        android:textColor="#E6FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/playerHandRecyclerView"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playerHandRecyclerView"
        android:layout_width="0dp"
        android:layout_height="152dp"
        android:layout_marginBottom="13dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        tools:itemCount="10"
        tools:listitem="@layout/item_card_mvp" />

</androidx.constraintlayout.widget.ConstraintLayout>